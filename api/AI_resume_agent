import streamlit as st
import PyPDF2
# --------------------
# Memory
# --------------------
if "history" not in st.session_state:
st.session_state.history = []
# --------------------
# Tool 1 - CV Reader
# --------------------

def read_cv(uploaded_file):
try:
reader = PyPDF2.PdfReader(uploaded_file)

```
    text = ""

    for page in reader.pages:
        page_text = page.extract_text()

        if page_text:
            text += page_text
    return text

except Exception as e:
    return f"Error reading CV: {e}"
```
# --------------------

# Tool 2 - Job Search
# --------------------
def search_jobs(job_title):
```
jobs = [
    {
        "title": "Data Analyst",
        "company": "Tech Corp",
        "skills": ["Python", "SQL", "Power BI"]
    },
    {
        "title": "Business Analyst",
        "company": "Analytics Ltd",
        "skills": ["Excel", "SQL"]
    },
    {
        "title": "Junior AI Engineer",
        "company": "AI Labs",
        "skills": ["Python", "Machine Learning"]
    }
]

results = []

for job in jobs:
    if job_title.lower() in job["title"].lower():
        results.append(job)
return results
```
# --------------------
# Tool 3 - Skill Match
# --------------------
def calculate_match(cv_text, skills):
```
score = 0
for skill in skills:
    if skill.lower() in cv_text.lower():
        score += 1

return round((score / len(skills)) * 100)
```

# --------------------

# Tool 4 - Email Generator

# --------------------

def generate_email(position):

```
return f"""
```

Subject: Application for {position}

Hello,

I would like to apply for the position of {position}.

My background includes data analysis, business systems,
and technical skills relevant to this role.

Thank you for your time and consideration.

Best regards,
Fatema Othman
"""
# --------------------

# Agent
# --------------------

def run_agent(cv_text, desired_role):

```
jobs = search_jobs(desired_role)

if len(jobs) == 0:
    return {
        "error": "No matching jobs found."
    }

results = []

for job in jobs:

    score = calculate_match(
        cv_text,
        job["skills"]
    )

    email = generate_email(
        job["title"]
    )

    results.append(
        {
            "job": job,
            "score": score,
            "email": email
        }
    )

return results
```
