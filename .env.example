# Pick a provider (default: groq). Copy this file to `.env`.
AGENT_PROVIDER=groq

# --- Free options -----------------------------------------------------------
# Groq: free, fast. Create a key at https://console.groq.com/keys
GROQ_API_KEY=

# Local Ollama: $0, offline. `ollama serve` then `ollama pull qwen2.5`,
# then set AGENT_PROVIDER=ollama (no key needed).

# Cerebras: free, fast. https://cloud.cerebras.ai
# CEREBRAS_API_KEY=

# --- Overrides (optional) ---------------------------------------------------
# AGENT_MODEL=llama-3.3-70b-versatile
# AGENT_MAX_STEPS=12
# AGENT_WORKSPACE=.            # sandbox root for file tools
# Point at ANY OpenAI-compatible endpoint directly:
# AGENT_BASE_URL=https://api.openai.com/v1
# AGENT_API_KEY=sk-...
