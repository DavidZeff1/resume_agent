# Copy to `.env` (gitignored). Secrets ONLY — never commit this with real values.

# Optional: enables LLM-backed scoring and the Agent SDK loop.
# Without it, the pipeline falls back to the deterministic heuristic scorer.
ANTHROPIC_API_KEY=

# Optional overrides:
# JOBAGENT_CONFIG=/path/to/config.yaml
# JOBAGENT_DATA_DIR=/path/to/data
